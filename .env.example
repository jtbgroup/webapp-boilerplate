# ============================================
# DEVELOPMENT (.env.dev)
# ============================================
# Dans docker-compose.dev.yml, H2 est utilisé par défaut
# Aucune variable nécessaire

# ============================================
# PRODUCTION - H2 (base de données en mémoire)
# ============================================
# DB_PROFILE=h2
# Aucune configuration DB supplémentaire

# ============================================
# PRODUCTION - PostgreSQL (base de données externe)
# ============================================
# Décommenter et configurer pour utiliser PostgreSQL
# DB_PROFILE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=webappboilerplate
# DB_USER=webappboilerplate
# DB_PASSWORD=your_secure_password_here

# ============================================
# JAVA TUNING (optionnel)
# ============================================
# JAVA_OPTS="-Xmx1024m -Xms512m"
